{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5433;Database=ridelance;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "super-duper-secret-value-that-should-be-in-user-secrets-minimum-32-chars",
    "Issuer": "ridelance",
    "Audience": "ridelance-frontend",
    "ExpirationInMinutes": 15
  },
  "Encryption": {
    "Key": "ridelance-document-encryption-secret-key-change-in-production"
  },
  "FileStorage": {
    "BasePath": "./uploads"
  }
}
